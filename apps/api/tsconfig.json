{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "baseUrl": "src",
    "paths": {
      "@engines/*": ["engines/*"],
      "@root/*": ["../../*"],
      "@types/*": ["../../types/*"]
    }
  },
  "include": ["src"]
}
