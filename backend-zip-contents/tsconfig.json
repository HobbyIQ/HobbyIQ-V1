{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    
    "types": ["mocha", "chai"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
