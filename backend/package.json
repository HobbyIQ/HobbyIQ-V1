{
  "name": "hobbyiq-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc && node scripts/write-build-info.cjs",
    "zip": "node ../zip.js",
    "ocr:report": "node scripts/ocr-quality-report.js",
    "ocr:readiness": "node scripts/ocr-release-readiness.js",
    "test": "vitest run --exclude \"**/harness/tier1/**\"",
    "test:harness": "vitest run harness --exclude \"**/harness/tier1/**\"",
    "test:harness:tier1": "vitest run harness/tier1"
  },
  "engines": {
    "node": ">=18.x"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "@azure/cosmos": "^4.9.3",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@opentelemetry/instrumentation-undici": "^0.28.0",
    "apn": "^2.2.0",
    "applicationinsights": "^3.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "ioredis": "^5.10.1",
    "openai": "^6.45.0",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
